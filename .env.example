# Copy to .env (bootstrap.sh does this for you and fills in the secrets).
# .env is gitignored. NEVER commit it.
#
# Secrets marked GENERATED are filled with strong random values by bootstrap.sh
# the first time it runs, and then kept stable on subsequent runs.

# ---------------------------------------------------------------------------
# Postgres (n8n state now, pgvector for semantic prioritization later)
# ---------------------------------------------------------------------------
POSTGRES_USER=n8n
POSTGRES_DB=n8n
POSTGRES_PASSWORD=CHANGE_ME_GENERATED

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
# Stable key that encrypts saved credentials. MUST NOT change once set, or
# every stored credential becomes unreadable. bootstrap.sh generates it once.
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATED

# How n8n refers to itself. For local-only use the defaults are fine.
# To receive Slack events you MUST set WEBHOOK_URL to a public HTTPS URL
# (e.g. a Tailscale Funnel hostname) — see README "Slack".
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# ---------------------------------------------------------------------------
# Ollama (CPU-only local LLM)
# ---------------------------------------------------------------------------
# Small, CPU-friendly model. bootstrap.sh pulls exactly this tag.
OLLAMA_MODEL=llama3.2:3b
# Keep the model resident between calls so triage stays fast.
OLLAMA_KEEP_ALIVE=1h

# ---------------------------------------------------------------------------
# ntfy (push to phone)
# ---------------------------------------------------------------------------
# Unguessable topic = your only access control on a personal setup.
# bootstrap.sh generates a random one. Subscribe to exactly this topic on your phone.
NTFY_TOPIC=CHANGE_ME_GENERATED
# Public base URL ntfy advertises in links/notifications.
# Set to your Tailscale Serve hostname once configured, e.g.
#   https://yourbox.your-tailnet.ts.net
NTFY_BASE_URL=http://127.0.0.1:8080

# ---------------------------------------------------------------------------
# Cloudflare Tunnel (optional — public ingress without opening ports)
# ---------------------------------------------------------------------------
# Only used by the `cloudflared` service, which runs under the "tunnel" profile:
#   docker compose --profile tunnel up -d
# Create a tunnel in the Cloudflare Zero Trust dashboard and paste its token here.
# Leave blank if you use Tailscale (or don't need public ingress) instead.
CLOUDFLARE_TUNNEL_TOKEN=

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
TZ=UTC
